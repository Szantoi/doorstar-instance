# Doorstar sziget példány-profil (multi-instance minta: kód = közös nexus-core dist,
# példány = ez a .env). Másold .env néven, és igazítsd a gépedhez.
#
# MIÉRT 13458? A 3456/3457 (és környéke) a VS Code Remote-SSH VPS-forwardja miatt
# árnyékolt lehet — a 1345x tartomány bizonyítottan ütközésmentes lokálisan.
# A repó-doksiban szereplő 3460-1 range a VPS-oldali kiosztás.

# ISLAND_ID: a futó példány azonosítója. NE nevezd át egyeztetés nélkül —
# a meglévő adatbázis-állapot (tokenek, üzenetek) ehhez az értékhez kötődik.
ISLAND_ID=cabinet-doorstar
COLLECTION_NAME=cabinetbilder-doorstar
PORT=13458

# Példány-útvonalak — minden a saját repóban él (izoláció):
KNOWLEDGE_BASE_PATH=C:/Users/szant/Documents/Development/doorstar-instance/docs/knowledge
TERMINALS_PATH=C:/Users/szant/Documents/Development/doorstar-instance/terminals
DATA_DIR=C:/Users/szant/Documents/Development/doorstar-instance/data

# ChromaDB (docker compose, 8001 — az 5432/5050 postgres/pgadmin ütközés elkerülésére)
CHROMA_URL=http://localhost:8001
